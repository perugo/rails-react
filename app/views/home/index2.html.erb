<% table_width_int = 1390 %>
<% genba_cell_width_int = 192 %>
<% start_date = Date.new(2025, 2, 16) %>
<% end_date   = Date.new(2025, 3, 17) %>
<% dates = (start_date..end_date).to_a %>
<% days_in_month = 30 %>
<% day_cells_width_int = table_width_int - genba_cell_width_int %>
<% day_cell_width_int = day_cells_width_int.to_f / days_in_month %>

<% genba_cell_width = "#{genba_cell_width_int}px" %>
<% day_cells_width = "#{day_cells_width_int}px" %>
<% day_cell_width  = "#{day_cell_width_int}px" %>

<% table_width = "#{table_width_int}px" %>
<% date_height = '55px' %>
<% schedule_height = 60 %>

<div class="bg-[#F2F5F8]">
  <div class="w-full pt-4">
    <div class="flex flex-row">
      <div class="flex flex-row bg-[#14046c] mr-4 text-white rounded-tr-md rounded-br-md">
        <div class="p-4 bg-white rounded-lg shadow-md"  style="width: 320px">
          <!-- 上部ボタン -->
          <button class="w-full text-indigo-900 font-semibold bg-indigo-100 hover:bg-indigo-200 py-2 rounded mb-2">
            ＋選択中のリソースを配置
          </button>

          <!-- フィルタ情報 -->
          <div class="text-sm text-gray-500 flex items-center justify-between mb-1">
            <span>下記期間に配置可能なリソースのみ表示中</span>
            <a href="#" class="text-indigo-600 hover:underline text-sm">×リセット</a>
          </div>

          <!-- 日付 -->
          <div class="flex items-center space-x-1 mb-4 text-gray-700 text-sm">
            <span>📍</span>
            <span>2025年11月30日朝</span>
            <span>〜</span>
            <span>2025年12月31日夜</span>
          </div>

          <!-- カテゴリ: 重機 -->
          <div class="mb-4">
            <div class="font-semibold text-gray-700 mb-2">重機 <span class="text-xs">⌃</span></div>
            <div class="flex flex-wrap gap-2">
              <% ['ブルドーザー', 'トンネル掘削機', 'パイプライン敷設機', '高所作業車', 'ダンプトラック', 'ミニショベル', 'コンプレッサー', 'アスファルトフィニッシャー', 'フォークリフト', 'クレーン車', 'パワーショベル', 'スカイリフト', '土砂運搬車', '振動ローラー', 'トンネル掘削機'].each do |machine| %>
                <label class="flex items-center space-x-1 bg-gray-100 px-2 py-1 rounded cursor-pointer">
                  <input type="checkbox" class="accent-indigo-600">
                  <span class="text-sm text-indigo-900"><%= machine %></span>
                </label>
              <% end %>
            </div>
          </div>

          <!-- カテゴリ: 人員 -->
          <div>
            <div class="font-semibold text-gray-700 mb-2">人員 <span class="text-xs">⌃</span></div>
            <div class="flex flex-wrap gap-2">
              <% ['ブルドーザー', 'トンネル掘削機', 'パイプライン敷設機', '高所作業車', 'ダンプトラック', 'ミニショベル', 'コンプレッサー', 'アスファルトフィニッシャー', 'フォークリフト', 'クレーン車', 'パワーショベル', 'スカイリフト', '土砂運搬車', '振動ローラー', 'トンネル掘削機'].each do |person| %>
                <label class="flex items-center space-x-1 bg-gray-100 px-2 py-1 rounded cursor-pointer">
                  <input type="checkbox" class="accent-indigo-600">
                  <span class="text-sm text-indigo-900"><%= person %></span>
                </label>
              <% end %>
            </div>
          </div>
        </div>
                <!-- >> ボタン -->
        <div class="w-8 h-10 flex items-center justify-center">
          <<
        </div>
      </div>
      <div class="flex flex-1 flex-col">
      </div>
    </div>
  </div>
</div>
