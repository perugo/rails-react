<%# ==== Parameters ==== %>
<% genba_cell_width_int = 152 %>
<% start_date = Date.new(2024, 12, 16) %>
<% end_date   = start_date + 31 %>
<% dates      = (start_date..end_date).to_a %>
<% genba_cell_width = "#{genba_cell_width_int}px" %>
<% source_panel_width = 380 %>
<% date_height = 45 %>
<% schedule_height = 48 %>

<div class="bg-[#F2F5F8]">
  <div class="w-full pt-4">
    <div class="flex flex-row">
      <div class="flex flex-row mr-4 h-[calc(100vh-16px)]">
        <div class="p-4 bg-white flex flex-col shadow-md"  style="width: <%= source_panel_width %>px">
          <!-- 上部ボタン -->
          <button class="w-full text-indigo-900 font-sm bg-indigo-100 hover:bg-indigo-200 text-sm py-2 rounded mb-2">
            ＋選択中のリソースを配置
          </button>

          <!-- フィルタ情報 -->
          <div class="text-sm text-gray-500 p-1 flex items-center justify-between mb-1" style="font-size: 11px;">
            <span>下記期間に配置可能なリソースのみ表示中</span>
            <a href="#" class="text-indigo-600 hover:underline text-xs">×リセット</a>
          </div>

          <!-- 日付 -->
          <div class="flex mb-4">
            <div class="bg-gray-100 rounded-sm w-full flex justify-center gap-3 p-1 text-gray-700 text-sm cursor-pointer">
              <span>2025年11月30日朝</span>
              <span>〜</span>
              <span>2025年12月31日夜</span>
            </div>
          </div>

          <div class="border-b border-gray-300"></div>
          <div class="flex-1 overflow-y-auto mt-2 space-y-6">
            <!-- カテゴリ: 重機 -->
            <div class="mb-4">
              <div class="font-semibold text-gray-700 mb-2">重機 <span class="text-xs">⌃</span></div>
              <div class="flex flex-wrap gap-2">
                <% ['ブルドーザー', 'トンネル掘削機', 'パイプライン敷設機', '高所作業車', 'ダンプトラック', 'ミニショベル', 'コンプレッサー', 'アスファルトフィニッシャー', 'フォークリフト', 'クレーン車', 'パワーショベル', 'スカイリフト', '土砂運搬車', '振動ローラー', 'トンネル掘削機'].each do |machine| %>
                  <label class="flex items-center space-x-1 bg-gray-100 px-2 py-1 rounded cursor-pointer">
                    <input type="checkbox" class="accent-indigo-600">
                    <span class="text-sm text-indigo-900"><%= machine %></span>
                  </label>
                <% end %>
              </div>
            </div>

            <!-- カテゴリ: 人員 -->
            <div>
              <div class="font-semibold text-gray-700 mb-2">人員 <span class="text-xs">⌃</span></div>
              <div class="flex flex-wrap gap-2">
                <% ['伊藤 太一', '山本 健太', '加藤 健太', '渡辺 俊介', '小林 直樹', '中村 翔太', '山田 大輔', '田中 健二', '鈴木 一郎'].each do |person| %>
                  <label class="flex items-center space-x-1 bg-gray-100 px-2 py-1 rounded cursor-pointer">
                    <span class="text-sm text-indigo-900"><%= person %></span>
                  </label>
                <% end %>
              </div>
            </div>
          </div>
        </div>
        <!-- >> ボタン -->
        <div class="w-8 h-full flex items-start justify-center rounded-tr-md rounded-br-md bg-[#14046c]">
          <img
            src="/svg/double_arrow_left.svg"
            class="w-[20px] h-[20px] mt-2"
            alt="リソース配置パネルの表示・非表示トグル"
          />
        </div>
      </div>

      <div class="flex flex-1 flex-col">
        <!-- ヘッダ操作エリア -->
        <div class="pr-4">
          <div class="flex items-center justify-between mb-2">
            <div class="flex items-center space-x-2">
              <button class="text-blue-900">今日</button>
              <select class="border rounded px-2 py-1"><option>1ヶ月表示</option></select>
            </div>
            <div class="flex items-center space-x-3">
              <% %w(重機 人員 機材 その他).each_with_index do |label, idx| %>
                <label class="flex items-center space-x-1 text-blue-900">
                  <input type="checkbox" class="accent-blue-900" <%= 'checked' if idx < 3 %> />
                  <span><%= label %></span>
                </label>
              <% end %>
              <button class="bg-indigo-100 text-indigo-900 font-medium px-3 py-1 rounded hover:bg-indigo-200">+ 配置登録</button>
              <button class="bg-indigo-100 text-indigo-900 font-medium px-3 py-1 rounded hover:bg-indigo-200">🛠 配置一括編集</button>
            </div>
          </div>

          <!-- ===== カレンダー本体 ===== -->
          <div class="relative z-0 pt-4 pl-4 flex flex-1 flex-col w-full bg-white">
            <!-- ==== 日付ヘッダ ==== -->
            <div class="flex">
              <!-- 左固定空セル -->
              <div class="flex flex-shrink-0" style="width:<%= genba_cell_width %>">
                <div class="flex-1 border-b border-r border-gray-300"></div>
              </div>

              <!-- 横スクロール領域 -->
              <div class="flex-1 overflow-x-auto">
                <!-- 月ラベル行 -->
                <% month_data = [] %>
                <% prev_month = nil; day_cnt = 0 %>
                <% dates.each_with_index do |d, idx| %>
                  <% prev_month ||= d.month %>
                  <% if d.month != prev_month %>
                    <% month_data << {year: d.year, month: prev_month, days: day_cnt} %>
                    <% prev_month = d.month; day_cnt = 0 %>
                  <% end %>
                  <% day_cnt += 1 %>
                  <% month_data << {year: d.year, month: prev_month, days: day_cnt} if idx == dates.size - 1 %>
                <% end %>

                <div class="flex min-w-full">
                  <% month_data.each_with_index do |m, i| %>
                    <div class="pl-3 text-gray-500 border-b border-gray-300 <%= 'border-r' unless i == month_data.size - 1 %>" style="flex:<%= m[:days] %> 0 0; min-width:0;">
                      <%= "#{m[:year]}年#{m[:month]}月" %>
                    </div>
                  <% end %>
                </div>

                <!-- 各日セル行 -->
                <div class="flex min-w-full">
                  <% dates.each_with_index do |date, i| %>
                    <%
                      day_color = case date.wday
                                  when 0 then 'text-red-500'   # 日曜
                                  when 6 then 'text-blue-500'  # 土曜
                                  else      'text-gray-500'   # 平日
                                  end
                    %>
                    <div class="flex-1 border-b border-gray-300 <%= 'border-r' unless i == dates.size - 1 %>">
                      <div class="flex flex-col items-center justify-center" style= "height: <%= date_height %>px">
                        <div class="text-sm pt-0.5 <%= day_color %>"><%= %w(日 月 火 水 木 金 土)[date.wday] %></div>
                        <div class="<%= day_color %> text-base font-semibold"><%= date.day %></div>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
            </div> <!-- /日付ヘッダ -->

            <!-- ==== スケジュール部 ==== -->
            <div class="flex flex-1 overflow-x-auto">
              <!-- 左固定現場名 -->
              <div class="flex-shrink-0" style="width:<%= genba_cell_width %>">
                <div class="flex items-center text-gray-700 border-r border-gray-300" style="height:<%= schedule_height * 2 %>px;">佐賀バルーン駅</div>
              </div>

              <!-- スケジュール行列 -->
              <div class="flex-1 flex flex-col">
                <% 2.times do %>
                  <div class="flex flex-1 min-h-[<%= schedule_height %>px] border-b border-gray-300 last:border-b-0">
                    <% dates.each_with_index do |_, i| %>
                      <div class="flex-1 min-w-0 border-gray-300 <%= 'border-r' unless i == dates.size - 1 %>"></div>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
