<% posts = [
  { id: 10001, title: "春の旅行記：桜満開の京都を歩く", author: "田中太郎", date: "2024/03/20" },
  { id: 10002, title: "美味しいカフェ探訪記", author: "佐藤花子", date: "2024/03/18" },
  { id: 10003, title: "プログラミング学習のコツ", author: "鈴木一郎", date: "2024/03/15" },
  { id: 10004, title: "読書感想文：最近読んだ小説について", author: "高橋美咲", date: "2024/03/12" },
  { id: 10005, title: "料理レシピ：手作りパスタに挑戦", author: "渡辺健太", date: "2024/03/10" },
  { id: 10006, title: "映画レビュー：話題の新作映画を観てきました", author: "山田太郎", date: "2024/03/08" }
] %>

<div>
  <h1 class="title">投稿管理</h1>
  <p class="subtitle mt-2">ユーザーの投稿を管理できます</p>

  <section class="card mt-8">
    <div class="card-body">
      <h2 class="card-title">検索・フィルター</h2>
      <div class="mt-4 grid grid-cols-2 gap-4">
        <div class="fieldset">
          <label for="search-title" class="fieldset-legend">タイトル</label>
          <input id="search-title" class="input w-full" placeholder="タイトルで検索" type="text" name="search-title" />
        </div>
        <div class="fieldset">
          <label for="search-author" class="fieldset-legend">投稿者名</label>
          <input id="search-author" class="input w-full" placeholder="投稿者名で検索" type="text" name="search-author" />
        </div>
      </div>
      <div class="mt-4 flex gap-4">
        <button type="button" class="btn btn-primary">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          検索
        </button>
        <button type="button" class="btn btn-neutral">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
          </svg>
          リセット
        </button>
      </div>
    </div>
  </section>

  <section class="card mt-6">
    <div class="card-body">
      <div class="mb-4 flex items-center justify-between">
        <h2 class="card-title">投稿一覧</h2>
        <div class="flex items-center gap-4">
          <span class="text-sm text-base-content/50"><%= posts.size %>件中 1-<%= posts.size %>件を表示</span>
        </div>
      </div>

      <div class="overflow-x-auto">
        <table class="table table-zebra">
          <thead>
            <tr>
              <th>タイトル</th>
              <th>投稿者名</th>
              <th>投稿日</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% posts.each do |post| %>
              <tr>
                <td>
                  <div>
                    <div class="font-medium"><%= post[:title] %></div>
                    <div class="text-sm text-base-content/50">ID: <%= post[:id] %></div>
                  </div>
                </td>
                <td><%= post[:author] %></td>
                <td><%= post[:date] %></td>
                <td>
                  <div class="flex gap-2">
                    <a class="btn btn-square btn-ghost" title="詳細を見る" href="/a-loop/posts/show">
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                      </svg>
                    </a>
                    <a class="btn btn-square btn-ghost" title="編集" href="/a-loop/posts/edit">
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                      </svg>
                    </a>
                    <button class="btn btn-square btn-ghost" title="削除">
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                      </svg>
                    </button>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <div class="mt-6 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <div class="text-sm break-keep text-base-content/50">表示件数</div>
          <select class="select select-sm">
            <option value="20">20件</option>
            <option value="50">50件</option>
            <option value="100">100件</option>
          </select>
        </div>
        <div class="join">
          <button class="btn join-item">‹</button>
          <button class="btn join-item">1</button>
          <button class="btn join-item">2</button>
          <button class="btn join-item btn-disabled">...</button>
          <button class="btn join-item">99</button>
          <button class="btn join-item">100</button>
          <button class="btn join-item">›</button>
        </div>
      </div>
    </div>
  </section>
</div>